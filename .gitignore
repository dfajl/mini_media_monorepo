# Dependencies and build artifacts
**/node_modules/
**/dist/
**/build/
**/coverage/
**/.nyc_output/
**/.output/
**/.nuxt/
**/.vite/

# Logs
**/logs/
**/*.log
**/npm-debug.log*
**/pnpm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/lerna-debug.log*

# Environment files
**/.env
**/.env.*
!**/.env.example

# Runtime/temp files
**/.temp/
**/.tmp/
**/pids/
**/*.pid
**/*.pid.lock
**/*.seed
**/report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# OS / IDE
**/.DS_Store
**/Thumbs.db
**/.idea/
**/.vscode/*
!**/.vscode/extensions.json
!**/.vscode/settings.json
!**/.vscode/tasks.json
!**/.vscode/launch.json